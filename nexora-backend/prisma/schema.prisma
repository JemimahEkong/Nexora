// Nexora — Prisma Schema
// Supports both SQLite (local dev) and PostgreSQL (Render/production).
// Switch is controlled entirely by DATABASE_URL in your environment:
//   Local:  DATABASE_URL="file:./dev.db"
//   Render: DATABASE_URL="postgresql://..." (from Render's DB panel)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = env("DATABASE_PROVIDER")
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────
// MERCHANT
// ─────────────────────────────────────────────────────────────────
model Merchant {
  id               String   @id @default(uuid())
  name             String
  email            String
  apiKey           String   @unique
  webhookSecret    String
  nombaAccountId   String
  merchantBalance  Float    @default(0)
  createdAt        DateTime @default(now())

  settlements      Settlement[]
  services         MerchantService[]
}

// ─────────────────────────────────────────────────────────────────
// CUSTOMER
// ─────────────────────────────────────────────────────────────────
model Customer {
  id          String   @id @default(uuid())
  firstName   String
  lastName    String
  email       String   @unique
  phone       String
  bvn         String?
  kycTier     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  virtualAccounts VirtualAccount[]
  invoices        Invoice[]
}

// ─────────────────────────────────────────────────────────────────
// VIRTUAL ACCOUNT
// ─────────────────────────────────────────────────────────────────
model VirtualAccount {
  id                   String   @id @default(uuid())
  accountName          String
  accountRef           String   @unique
  accountNumber        String?
  bankName             String   @default("Nombank MFB")
  bankAccountName      String?
  status               String   @default("ACTIVE")
  balance              Float    @default(0)
  expectedAmount       Float?
  nombaAccountHolderId String?
  subAccountId         String?

  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transactions  Transaction[]
  ledgerEntries LedgerEntry[]
}

// ─────────────────────────────────────────────────────────────────
// INVOICE
// ─────────────────────────────────────────────────────────────────
model Invoice {
  id          String   @id @default(uuid())
  reference   String   @unique
  amount      Float
  amountPaid  Float    @default(0)
  status      String   @default("PENDING")
  dueDate     DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])

  transactions Transaction[]
}

// ─────────────────────────────────────────────────────────────────
// TRANSACTION
// ─────────────────────────────────────────────────────────────────
model Transaction {
  id               String   @id @default(uuid())
  reference        String   @unique
  nombaRequestId   String?  @unique
  nombaSessionId   String?
  amount           Float
  senderName       String?
  senderAccount    String?
  narration        String?
  status           String   @default("PENDING")
  reconciledAt     DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  virtualAccountId String
  virtualAccount   VirtualAccount @relation(fields: [virtualAccountId], references: [id])

  invoiceId        String?
  invoice          Invoice?  @relation(fields: [invoiceId], references: [id])

  exception        Exception?
  ledgerEntries    LedgerEntry[]
}

// ─────────────────────────────────────────────────────────────────
// EXCEPTION
// ─────────────────────────────────────────────────────────────────
model Exception {
  id            String   @id @default(uuid())
  type          String
  reason        String
  amount        Float
  senderName    String?
  resolved      Boolean  @default(false)
  resolvedAt    DateTime?
  resolvedBy    String?
  createdAt     DateTime @default(now())

  transactionId String   @unique
  transaction   Transaction @relation(fields: [transactionId], references: [id])
}

// ─────────────────────────────────────────────────────────────────
// LEDGER ENTRY
// ─────────────────────────────────────────────────────────────────
model LedgerEntry {
  id               String   @id @default(uuid())
  type             String
  amount           Float
  balanceAfter     Float
  description      String
  createdAt        DateTime @default(now())

  virtualAccountId String
  virtualAccount   VirtualAccount @relation(fields: [virtualAccountId], references: [id])

  transactionId    String?
  transaction      Transaction? @relation(fields: [transactionId], references: [id])
}

// ─────────────────────────────────────────────────────────────────
// MERCHANT SERVICE
// ─────────────────────────────────────────────────────────────────
model MerchantService {
  id          String   @id @default(uuid())
  type        String
  destination String
  amount      Float
  status      String   @default("PENDING")
  reference   String   @unique
  nombaRef    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  merchantId  String
  merchant    Merchant @relation(fields: [merchantId], references: [id])
}

// ─────────────────────────────────────────────────────────────────
// SETTLEMENT
// ─────────────────────────────────────────────────────────────────
model Settlement {
  id         String   @id @default(uuid())
  amount     Float
  status     String   @default("COMPLETED")
  reference  String   @unique
  createdAt  DateTime @default(now())

  merchantId String
  merchant   Merchant @relation(fields: [merchantId], references: [id])
}

// ─────────────────────────────────────────────────────────────────
// WEBHOOK EVENT LOG
// ─────────────────────────────────────────────────────────────────
model WebhookEvent {
  id          String   @id @default(uuid())
  requestId   String   @unique
  event       String
  payload     String
  signature   String
  processed   Boolean  @default(false)
  processedAt DateTime?
  error       String?
  createdAt   DateTime @default(now())
}
